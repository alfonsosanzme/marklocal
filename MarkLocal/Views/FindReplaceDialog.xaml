<Window x:Class="MarkLocal.Views.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar y reemplazar"
        Height="240" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ChromeForegroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Buscar" VerticalAlignment="Center"/>
        <TextBox x:Name="FindBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Reemplazar" VerticalAlignment="Center"/>
        <TextBox x:Name="ReplaceBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <CheckBox x:Name="MatchCaseCheck" Content="Coincidir mayúsculas/minúsculas" Margin="0,0,12,0"/>
            <CheckBox x:Name="WholeWordCheck" Content="Palabra completa"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8" Foreground="{DynamicResource MutedForegroundBrush}"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Buscar siguiente" Width="120" Margin="0,0,8,0" Click="OnFindNext" IsDefault="True"/>
            <Button Content="Reemplazar" Width="100" Margin="0,0,8,0" Click="OnReplaceOnce"/>
            <Button Content="Reemplazar todo" Width="120" Margin="0,0,8,0" Click="OnReplaceAll"/>
            <Button Content="Cerrar" Width="80" Click="OnClose" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
