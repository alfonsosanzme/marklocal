<Window x:Class="MarkLocal.Views.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MarkLocal"
        Title="{local:Loc views.find.title}"
        Height="240" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ChromeForegroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="{local:Loc views.find.find}" VerticalAlignment="Center"/>
        <TextBox x:Name="FindBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="{local:Loc views.find.replace}" VerticalAlignment="Center"/>
        <TextBox x:Name="ReplaceBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <CheckBox x:Name="MatchCaseCheck" Content="{local:Loc views.find.matchCase}" Margin="0,0,12,0"/>
            <CheckBox x:Name="WholeWordCheck" Content="{local:Loc views.find.wholeWord}"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8" Foreground="{DynamicResource MutedForegroundBrush}"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{local:Loc views.find.next}" Width="120" Margin="0,0,8,0" Click="OnFindNext" IsDefault="True"/>
            <Button Content="{local:Loc views.find.replaceOnce}" Width="100" Margin="0,0,8,0" Click="OnReplaceOnce"/>
            <Button Content="{local:Loc views.find.replaceAll}" Width="120" Margin="0,0,8,0" Click="OnReplaceAll"/>
            <Button Content="{local:Loc views.find.close}" Width="80" Click="OnClose" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
