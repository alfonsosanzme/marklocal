<Window x:Class="MarkLocal.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MarkLocal"
        Title="{local:Loc views.settings.title}"
        Height="720" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ChromeForegroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{local:Loc views.settings.section.appearance}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{local:Loc views.settings.theme}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ThemeCombo" Grid.Row="0" Grid.Column="1" Margin="0,4">
                        <ComboBoxItem Content="{local:Loc views.settings.theme.system}"/>
                        <ComboBoxItem Content="{local:Loc views.settings.theme.light}"/>
                        <ComboBoxItem Content="{local:Loc views.settings.theme.dark}"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{local:Loc views.settings.language}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="LanguageCombo" Grid.Row="1" Grid.Column="1" Margin="0,4">
                        <ComboBoxItem Tag="auto" Content="{local:Loc views.settings.language.auto}"/>
                        <ComboBoxItem Tag="en" Content="English"/>
                        <ComboBoxItem Tag="es" Content="Español"/>
                        <ComboBoxItem Tag="de" Content="Deutsch"/>
                        <ComboBoxItem Tag="fr" Content="Français"/>
                        <ComboBoxItem Tag="zh-Hans" Content="中文（简体）"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{local:Loc views.settings.fontFamily}" VerticalAlignment="Center"/>
                    <TextBox x:Name="FontFamilyBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{local:Loc views.settings.fontSize}" VerticalAlignment="Center"/>
                    <TextBox x:Name="FontSizeBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{local:Loc views.settings.previewFontSize}" VerticalAlignment="Center"/>
                    <TextBox x:Name="PreviewFontSizeBox" Grid.Row="4" Grid.Column="1" Margin="0,4"/>

                    <CheckBox x:Name="WordWrapCheck" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="{local:Loc views.settings.wordWrap}" Margin="0,8"/>
                </Grid>

                <TextBlock Text="{local:Loc views.settings.section.editor}" FontWeight="SemiBold" Margin="0,8,0,6"/>
                <CheckBox x:Name="LineNumbersCheck" Content="{local:Loc views.settings.lineNumbers}" Margin="0,4"/>
                <CheckBox x:Name="AutoPairCheck" Content="{local:Loc views.settings.autoPair}" Margin="0,4"/>
                <CheckBox x:Name="OutlineCheck" Content="{local:Loc views.settings.outline}" Margin="0,4"/>

                <TextBlock Text="{local:Loc views.settings.section.document}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{local:Loc views.settings.lineEnding}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="LineEndingCombo" Grid.Row="0" Grid.Column="1" Margin="0,4">
                        <ComboBoxItem Content="{local:Loc views.settings.lineEnding.crlf}"/>
                        <ComboBoxItem Content="{local:Loc views.settings.lineEnding.lf}"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{local:Loc views.settings.assetsFolder}" VerticalAlignment="Center"/>
                    <TextBox x:Name="AssetsFolderBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
                </Grid>

                <CheckBox x:Name="CopyImagesCheck" Content="{local:Loc views.settings.copyImages}" Margin="0,8"/>
                <CheckBox x:Name="AllowHtmlCheck" Content="{local:Loc views.settings.allowHtml}" Margin="0,4"/>

                <TextBlock Text="{local:Loc views.settings.section.preview}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{local:Loc views.settings.debounce}" VerticalAlignment="Center"/>
                    <TextBox x:Name="DebounceBox" Grid.Column="1" Margin="0,4"/>
                </Grid>

                <TextBlock Text="{local:Loc views.settings.section.customCss}" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <TextBlock Text="{local:Loc views.settings.customCss.hint}"
                           Margin="0,0,0,6" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                <TextBox x:Name="CustomCssBox" IsReadOnly="True" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{local:Loc views.settings.customCss.browse}" Width="100" Margin="0,0,6,0" Click="OnBrowseCustomCss"/>
                    <Button Content="{local:Loc views.settings.customCss.createTemplate}" Width="120" Margin="0,0,6,0" Click="OnCreateCssTemplate"/>
                    <Button Content="{local:Loc views.settings.customCss.openInEditor}" Width="140" Margin="0,0,6,0" Click="OnOpenCustomCss"/>
                    <Button Content="{local:Loc views.settings.customCss.remove}" Width="80" Click="OnRemoveCustomCss"/>
                </StackPanel>

                <TextBlock Text="{local:Loc views.settings.section.windows}" FontWeight="SemiBold" Margin="0,12,0,6"/>
                <TextBlock x:Name="AssociationStatus" Text="" Margin="0,0,0,6" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AssociateButton" Content="{local:Loc views.settings.associate}" Width="180" Margin="0,0,8,0" Click="OnAssociateClicked"/>
                    <Button x:Name="DisassociateButton" Content="{local:Loc views.settings.disassociate}" Width="160" Click="OnDisassociateClicked"/>
                </StackPanel>

                <TextBlock x:Name="ShellNewStatus" Text="" Margin="0,12,0,6" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="EnableShellNewButton" Content="{local:Loc views.settings.shellNew.add}" Width="200" Margin="0,0,8,0" Click="OnEnableShellNewClicked"/>
                    <Button x:Name="DisableShellNewButton" Content="{local:Loc views.settings.shellNew.remove}" Width="200" Click="OnDisableShellNewClicked"/>
                </StackPanel>

                <TextBlock x:Name="ConfigPathHint" Text="" Margin="0,16,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{local:Loc views.settings.cancel}" Width="100" Margin="0,0,8,0" Click="OnCancel" IsCancel="True"/>
            <Button Content="{local:Loc views.settings.save}" Width="120" Click="OnAccept" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
