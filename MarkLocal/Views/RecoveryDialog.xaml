<Window x:Class="MarkLocal.Views.RecoveryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MarkLocal"
        Title="{local:Loc views.recovery.title}"
        Height="440" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ChromeForegroundBrush}"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="HeaderText"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{local:Loc views.recovery.subtitle}"
                       Margin="0,4,0,0"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <ListBox x:Name="DraftList"
                 Grid.Row="1"
                 Background="{DynamicResource EditorBackgroundBrush}"
                 BorderBrush="{DynamicResource DividerBrush}"
                 BorderThickness="1"
                 SelectionMode="Single"
                 MouseDoubleClick="OnListDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{DynamicResource MutedForegroundBrush}" FontSize="12">
                            <Run Text="{local:Loc views.recovery.modified}"/>
                            <Run Text="{Binding LocalModifiedText, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding SizeText, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding OriginalPathText, Mode=OneWay}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock x:Name="FolderHint"
                   Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="{DynamicResource MutedForegroundBrush}"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{local:Loc views.recovery.discardOne}" Width="130" Margin="0,0,8,0" Click="OnDiscardOne"/>
            <Button Content="{local:Loc views.recovery.discardAll}" Width="130" Margin="0,0,8,0" Click="OnDiscardAll"/>
            <Button Content="{local:Loc views.recovery.keepAll}" Width="130" Margin="0,0,8,0" Click="OnKeepAll" IsCancel="True"/>
            <Button Content="{local:Loc views.recovery.recover}" Width="110" Click="OnRecover" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
